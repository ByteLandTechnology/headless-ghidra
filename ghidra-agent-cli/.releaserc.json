{
  "branches": ["main"],
  "tagFormat": "v${version}",
  "plugins": [
    [
      "@semantic-release/commit-analyzer",
      {
        "preset": "conventionalcommits",
        "parserOpts": {
          "noteKeywords": [
            "BREAKING CHANGE",
            "BREAKING-CHANGE",
            "BREAKING CHANGES"
          ]
        },
        "releaseRules": [
          { "breaking": true, "release": "major" },
          { "scope": "plan", "release": false },
          { "scope": "spec", "release": false },
          { "scope": "tasks", "release": false },
          { "type": "feat", "release": "minor" },
          { "type": "fix", "release": "patch" },
          { "type": "perf", "release": "patch" },
          { "type": "refactor", "release": "patch" },
          { "type": "docs", "release": "patch" },
          { "type": "build", "release": "patch" },
          { "type": "ci", "release": "patch" },
          { "type": "revert", "release": "patch" },
          { "type": "chore", "scope": "deps", "release": "patch" },
          { "type": "chore", "scope": "release", "release": false }
        ]
      }
    ],
    [
      "@semantic-release/release-notes-generator",
      { "preset": "conventionalcommits" }
    ],
    ["@semantic-release/changelog", { "changelogFile": "CHANGELOG.md" }],
    ["@semantic-release/npm", { "pkgRoot": "npm/main", "npmPublish": false }],
    [
      "@semantic-release/exec",
      {
        "prepareCmd": "node scripts/release/build-binaries.mjs ${nextRelease.version} && node scripts/release/sync-platform-packages.mjs ${nextRelease.version}",
        "publishCmd": "node scripts/release/publish-npm-packages.mjs ${nextRelease.version}"
      }
    ],
    [
      "@semantic-release/github",
      {
        "successComment": false,
        "failComment": false,
        "releasedLabels": false,
        "assets": [
          { "path": "dist/*.tar.gz", "label": "release archive" },
          { "path": "dist/*.sha256", "label": "sha256 checksum" },
          { "path": "dist/provenance.json", "label": "build provenance" }
        ]
      }
    ],
    [
      "@semantic-release/git",
      {
        "assets": [
          "CHANGELOG.md",
          "Cargo.toml",
          "Cargo.lock",
          "npm/main/package.json"
        ],
        "message": "chore(release): ${nextRelease.version}\n\n${nextRelease.notes}"
      }
    ]
  ]
}
